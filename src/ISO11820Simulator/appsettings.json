  "FileStorage": {
    "BaseDirectory": ".",
    "TestDataDirectory": "TestData"
  },
  "Report": {
    "OutputDirectory": "Reports",
    "EnablePdfExport": true,
    "EnableExcelExport": true
  },
  "Ui": {
    "Theme": "ModernDark"
